# Copy to `.env.local` and adjust. All are optional.

# Session passphrase for the lock gate when no auth endpoint is set (default: "sterling").
VITE_SESSION_PASSPHRASE=sterling

# Optional: when set, the lock gate verifies passphrases server-side (POST { passphrase }).
# VITE_AUTH_ENDPOINT=https://api.example.com/auth/session

# "Send to Asana" creates the task via the bundled Netlify function
# (netlify/functions/asana.mts), which reads these SERVER-SIDE vars in Netlify.
# Set them in Netlify → Site settings → Environment variables (NOT VITE_-prefixed,
# so they never reach the browser). When ASANA_TOKEN is unset the action exports
# the payload as JSON instead.
#
#   ASANA_TOKEN=...            # Asana Personal Access Token (required)
#   ASANA_PROJECT_GID=...      # Project to file tasks under (recommended)
#   ASANA_WORKSPACE_GID=...    # Optional; defaults to the token owner's workspace
#
# Optional: override the backend route the SPA POSTs to (defaults to the bundled
# function at /.netlify/functions/asana).
# VITE_ASANA_WEBHOOK_URL=https://api.example.com/integrations/asana

# ---------------------------------------------------------------------------
# AI Compliance Co-pilot (optional, governed) — drafts a polished compliance
# narrative via the bundled Netlify function (netlify/functions/ai-copilot.mts).
# The key is read SERVER-SIDE in Netlify (NOT VITE_-prefixed, so it never reaches
# the browser). When ANTHROPIC_API_KEY is unset the function returns 503 and the
# app silently keeps the deterministic narrative. See docs/AI-REGISTER.md.
#
#   ANTHROPIC_API_KEY=...                     # Anthropic API key (enables the feature)
#   AI_COPILOT_MODEL=claude-haiku-4-5-20251001 # Optional pinned-model override
#
# Optional: override the backend route the SPA POSTs to (defaults to the bundled
# function at /.netlify/functions/ai-copilot).
# VITE_AI_COPILOT_URL=https://api.example.com/integrations/ai-copilot

# Optional: mirror every activity-log entry to a durable backend audit store
# (Layer 6). Off unless set; failures are swallowed and the in-app log remains
# the source of truth. POST body is the activity entry { id, ts, message }.
# VITE_AUDIT_ENDPOINT=https://api.example.com/audit/log

# ---------------------------------------------------------------------------
# Expiry notifier (scripts/expiry-notifier.mjs) — reads expiry dates from the
# Asana customer-record descriptions and files follow-up tasks for anything
# expired/overdue. Runs via .github/workflows/expiry-notifier.yml (daily) or
# locally with `npm run expiry:notify`. No email; no Asana date columns.
#
#   ASANA_TOKEN=...                # Asana Personal Access Token (the only required value)
#
# Everything else is baked into scripts/expiry-notifier.mjs as a default and is
# only needed to OVERRIDE one (defaults shown):
#   RENEWALS_PROJECT_GID=1215884707932023  # "Compliance Renewals" project
#   ASANA_PROJECT_GID=1214107620220121     # source "Customer Database" project
#   RISK_PROJECT_GID=1215653768729951      # "Risk Assessments" project (risk ratings)
#   ASSIGNEE_GID=1213645083721304          # who renewal tasks are assigned to
#   ASANA_WORKSPACE_GID=1213645083721316
#   REVIEW_INTERVAL_MONTHS=12              # fallback review cadence (unknown risk)
#   REVIEW_INTERVAL_HIGH_MONTHS=1          # CDD review cadence: High risk
#   REVIEW_INTERVAL_MEDIUM_MONTHS=3        # CDD review cadence: Medium risk
#   REVIEW_INTERVAL_LOW_MONTHS=6           # CDD review cadence: Low risk
#   SCREENING_INTERVAL_MONTHS=1            # per-customer re-screening cadence
#   DAILY_SCREENING=1                      # file one book-wide screening task/day
#   REMINDER_LEAD_DAYS=2                   # also flag items expiring within N days
#   ASANA_EXPIRY_FIELD_GID=1215871723101263  # "Expiry Date" column (license source)
#   TIMEZONE=Asia/Dubai                    # how "today" is determined
#   DRY_RUN=1                              # print instead of creating tasks
