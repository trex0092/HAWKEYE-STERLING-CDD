# Copy to `.env.local` and adjust. All are optional.

# Session passphrase for the lock gate when no auth endpoint is set (default: "sterling").
VITE_SESSION_PASSPHRASE=sterling

# Optional: when set, the lock gate verifies passphrases server-side (POST { passphrase }).
# VITE_AUTH_ENDPOINT=https://api.example.com/auth/session

# "Send to Asana" creates the task via the bundled Netlify function
# (netlify/functions/asana.mts), which reads these SERVER-SIDE vars in Netlify.
# Set them in Netlify → Site settings → Environment variables (NOT VITE_-prefixed,
# so they never reach the browser). When ASANA_TOKEN is unset the action exports
# the payload as JSON instead.
#
#   ASANA_TOKEN=...            # Asana Personal Access Token (required)
#   ASANA_PROJECT_GID=...      # Project to file tasks under (recommended)
#   ASANA_WORKSPACE_GID=...    # Optional; defaults to the token owner's workspace
#
# Optional: override the backend route the SPA POSTs to (defaults to the bundled
# function at /.netlify/functions/asana).
# VITE_ASANA_WEBHOOK_URL=https://api.example.com/integrations/asana
